{
	"name": "@infinityfx/lively",
	"version": "5.0.0-alpha.15",
	"type": "module",
	"description": "Feature complete, lightweight react animation library.",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"default": "./dist/index.js"
		},
		"./hooks": {
			"types": "./dist/types/hooks.d.ts",
			"default": "./dist/hooks.js"
		},
		"./presets": {
			"types": "./dist/types/presets.d.ts",
			"default": "./dist/presets.js"
		}
	},
	"typesVersions": {
		"*": {
			"hooks": [
				"./dist/types/hooks.d.ts"
			],
			"presets": [
				"./dist/types/presets.d.ts"
			]
		}
	},
	"repository": "infinityfx-llc/lively",
	"author": "InfinityFX <contact@infinity-fx.com> (https://infinityfx.dev)",
	"license": "GPL-3.0",
	"bugs": "https://github.com/infinityfx-llc/lively/issues",
	"homepage": "https://github.com/infinityfx-llc/lively#readme",
	"funding": "https://ko-fi.com/infinityfx",
	"keywords": [
		"animation",
		"keyframe",
		"react",
		"transition",
		"morph",
		"animate",
		"reactive",
		"lightweight",
		"performant"
	],
	"scripts": {
		"build": "rollup -c --environment NODE_ENV:production",
		"watch": "rollup -c -w"
	},
	"dependencies": {
		"tslib": "^2.8.1"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^0.4.4",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rollup": "^4.59.0",
		"rollup-plugin-delete": "^3.0.2",
		"rollup-plugin-preserve-directives": "^0.4.0",
		"typescript": "^5.9.3"
	},
	"sideEffects": false
}